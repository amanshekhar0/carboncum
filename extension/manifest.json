{
  "manifest_version": 3,
  "name": "CarbonTwin - Eco Coach",
  "version": "1.1.0",
  "description": "Visualize your digital carbon footprint and save \u20b9 in real-time.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "idle"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "http://localhost:5173/*",
    "http://localhost:5174/*",
    "https://carboncum.onrender.com/*",
    "https://carbontwin-tau.vercel.app/*",
    "https://carbontwin.vercel.app/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:5174/*",
        "https://carbontwin-tau.vercel.app/*",
        "https://carbontwin.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CarbonTwin - Eco Coach",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
